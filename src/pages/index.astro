---
import Layout from '../layouts/Layout.astro';

// Placeholder copy. Tagline carries the "what" (name says "where") - design-brief.md.
const tagline = 'Design og produksjon';
---

<Layout title="Lokalverket" description="Lokalverket - kommer snart.">
  <main>
    <p class="eyebrow">Kommer snart</p>
    <h1 class="wordmark"><span class="lokal">lokal</span><span class="verket">verket</span></h1>
    <p class="tagline">{tagline}</p>
    <p class="contact">
      <a href="mailto:post@lokalverket.no">post@lokalverket.no</a>
    </p>
  </main>
</Layout>

<style>
  main {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    text-align: center;
    padding: var(--space-8) var(--space-6);
    max-width: var(--measure);
    margin: 0 auto;
  }

  .eyebrow {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-muted);
  }

  .wordmark {
    margin: 0;
    font-family: var(--font-wordmark);
    font-size: var(--text-4xl);
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .wordmark .lokal {
    color: var(--grey-500);
    font-weight: 300;
  }

  .wordmark .verket {
    color: var(--paper);
    font-weight: 700;
  }

  .tagline {
    margin: 0;
    color: var(--paper);
    font-size: var(--text-lg);
  }

  .contact {
    margin: var(--space-6) 0 0;
    font-size: var(--text-sm);
  }

  .contact a {
    color: var(--color-link);
    text-decoration: none;
    border-bottom: 1px solid var(--color-link);
    padding-bottom: 2px;
    transition: color 0.15s ease;
  }

  .contact a:hover {
    color: var(--paper);
  }
</style>
